# Postgres connection. In Vercel, adding the Vercel Postgres (Neon) integration
# auto-populates POSTGRES_PRISMA_URL (pooled, used at runtime) and
# POSTGRES_URL_NON_POOLING (direct, used for migrations). For local dev, point
# both at any Postgres instance (e.g. a local `docker run postgres` container).
POSTGRES_PRISMA_URL="postgresql://postgres:postgres@localhost:5432/vaultbox"
POSTGRES_URL_NON_POOLING="postgresql://postgres:postgres@localhost:5432/vaultbox"

# Session signing secret (HS256). Generate your own long random value for production.
SESSION_SECRET="generate-a-long-random-secret-here"

# Seed admin account (used once by `npm run seed:admin`).
ADMIN_EMAIL="admin@vaultbox.local"
ADMIN_PASSWORD="change-me-before-seeding"
ADMIN_NAME="System Admin"

# RSA keypair for hybrid file encryption. Locally, `npm run generate:keys` writes
# PEM files under ./keys/ and RSA_PUBLIC_KEY_PATH/RSA_PRIVATE_KEY_PATH (below) are
# used. In production, set RSA_PUBLIC_KEY / RSA_PRIVATE_KEY instead — the ./keys
# directory is gitignored and won't exist on a deployed instance. The generate:keys
# script prints ready-to-paste RSA_PUBLIC_KEY / RSA_PRIVATE_KEY values.
RSA_PUBLIC_KEY_PATH="./keys/rsa_public.pem"
RSA_PRIVATE_KEY_PATH="./keys/rsa_private.pem"
# RSA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"
# RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Vercel Blob token (Project Settings → Storage → create a Blob store). When set,
# encrypted file blobs are stored there instead of the local ./storage directory —
# required for Vercel deployments, since serverless functions can't persist local
# disk writes between requests.
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Local fallback directory for encrypted file blobs, used only when
# BLOB_READ_WRITE_TOKEN is not set (i.e. local dev).
STORAGE_DIR="./storage"
