DATABASE_URL="file:./dev.db"

# Session signing secret (HS256). Generate your own long random value for production.
SESSION_SECRET="generate-a-long-random-secret-here"

# Seed admin account (used once by `npm run seed:admin`).
ADMIN_EMAIL="admin@vaultbox.local"
ADMIN_PASSWORD="change-me-before-seeding"
ADMIN_NAME="System Admin"

# Paths to the RSA keypair used for hybrid file encryption (generated by `npm run generate:keys`).
RSA_PUBLIC_KEY_PATH="./keys/rsa_public.pem"
RSA_PRIVATE_KEY_PATH="./keys/rsa_private.pem"

# Local directory where encrypted file blobs are written.
STORAGE_DIR="./storage"
